generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model leetcode_solutions {
  id            BigInt    @id @default(autoincrement())
  version       String    @unique
  device_id     String
  problem_id    String
  title_slug    String?
  language      String
  code          String
  solution_hash String
  status        String?
  submitted_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([title_slug, solution_hash], map: "leetcode_solutions_slug_hash_idx")
  @@index([problem_id, device_id], map: "leetcode_solutions_problem_device_idx")
}

model leetcode_study_plan {
  device_id      String   @id
  payload        Json
  schema_version Int      @default(1)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)
}

model leetcode_study_plan_templates {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  payload     Json
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  is_active   Boolean  @default(true)
  sort_order  Int?

  @@index([is_active, sort_order], map: "leetcode_study_plan_templates_active_idx")
}

model QuestionReview {
  id          String   @id @default(cuid())
  questionId  String?
  questionSlug String?
  name        String?
  imageUrl    String?
  bucketName  String
  text        String
  codeJson    Json     @default("[]")
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}